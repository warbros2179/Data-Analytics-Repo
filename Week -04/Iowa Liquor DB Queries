-- 1. Create a list of all transactions for your chosen [Category/Vendor] that
-- took place in the last quarter of 2014, sorted by the total sale amount from highest to lowest.
SELECT *
FROM public.sales

SELECT date, category_name, total :: money 
FROM public.sales
WHERE category_name ILIKE '%GINS%'
	AND date BETWEEN '2014-10-01' AND '2014-12-31'
ORDER BY total DESC 

-- 2. Which transactions for your [Category/Vendor] had a bottle quantity greater than 12? 
-- Display the date, store number, item description, and total amount.

SELECT category_name, date, store, description, bottle_qty, total
FROM public.sales
WHERE bottle_qty > '12'
	AND category_name ILIKE '%GINS%'

-- 3. Find all products in the products_table whose item_description contains a specific 
-- keyword (e.g., 'Limited', 'Spiced'). What categories do they belong to?

SELECT category_name,item_description
FROM public.products
WHERE item_description ILIKE '%limited%'
	OR item_description ILIKE '%spiced%'
	OR item_description ILIKE '%premium%'
	OR item_description ILIKE '%rare%'

-- 4. What is the total sales revenue and the average bottle price (btl_price) for 
-- your chosen [Category/Vendor]? 

SELECT category_name, SUM(total) :: money AS total_revenue, ROUND(AVG(btl_price :: numeric), 2)
FROM public.sales
WHERE category_name ILIKE '%Gins%'
GROUP BY 1

-- 5. How many transactions were recorded for each specific item description within your 
-- chosen [Category]? Which specific product is the most frequently purchased?

SELECT description, COUNT (item)
FROM public.sales
WHERE category_name ILIKE '%GINS%'
GROUP BY 1
ORDER BY COUNT (item) DESC

